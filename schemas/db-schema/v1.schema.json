{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "db-schema/v1",
  "title": "db-schema/v1 body",
  "description": "agent-knowledge-governance-json-spec.md §4.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["owner", "table", "catalog", "purpose", "columnDescs"],
  "properties": {
    "owner": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
    "table": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["columns", "primaryKey", "fetchedAt"],
      "properties": {
        "columns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "type", "nullable"],
            "properties": {
              "name": { "type": "string", "pattern": "\\S" },
              "type": { "type": "string", "pattern": "\\S" },
              "nullable": { "type": "boolean" },
              "default": { "type": ["string", "null"] },
              "comment": { "type": ["string", "null"] }
            }
          }
        },
        "primaryKey": {
          "type": "array",
          "items": { "type": "string", "pattern": "\\S" }
        },
        "foreignKeys": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["column", "refTable", "refColumn"],
            "properties": {
              "column": { "type": "string", "pattern": "\\S" },
              "refTable": { "type": "string", "pattern": "\\S" },
              "refColumn": { "type": "string", "pattern": "\\S" }
            }
          }
        },
        "indexes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "unique", "columns"],
            "properties": {
              "name": { "type": "string", "pattern": "\\S" },
              "unique": { "type": "boolean" },
              "columns": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "pattern": "\\S" }
              }
            }
          }
        },
        "numRows": { "type": ["number", "null"] },
        "lastAnalyzed": { "type": ["string", "null"] },
        "tableComment": { "type": ["string", "null"] },
        "fetchedAt": { "type": "string", "pattern": "\\S" }
      }
    },
    "purpose": { "$ref": "common/tiered-value.v1" },
    "columnDescs": {
      "type": "object",
      "additionalProperties": { "$ref": "common/tiered-value.v1" }
    },
    "queries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sql", "note"],
        "properties": {
          "sql": { "type": "string", "pattern": "\\S" },
          "note": { "$ref": "common/tiered-value.v1" }
        }
      }
    }
  }
}
