{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "unclassified/v1",
  "title": "unclassified/v1 sidecar meta",
  "description": "agent-knowledge-governance-json-spec.md §4.5 — the only type whose truth is md, not JSON. This schema validates the WHOLE sidecar meta document (envelope fields inlined, no body key) — unlike the other types, where the type schema validates only envelope.body.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "id", "keywords", "status"],
  "properties": {
    "schema": { "const": "unclassified/v1" },
    "id": { "type": "string", "pattern": "^[a-z0-9._-]+$" },
    "keywords": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kw", "inject"],
        "properties": {
          "kw": { "type": "string", "pattern": "^[a-z0-9_. -]+$" },
          "inject": { "type": "string", "enum": ["full", "pointer"] }
        }
      }
    },
    "status": { "type": "string", "enum": ["active", "archived"] }
  }
}
