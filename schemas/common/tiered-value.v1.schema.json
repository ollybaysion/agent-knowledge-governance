{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "common/tiered-value.v1",
  "title": "tiered-value",
  "description": "Shared leaf shape for every slot a human's interpretation lives in. See agent-knowledge-governance-json-spec.md §3.",
  "type": "object",
  "additionalProperties": false,
  "required": ["text", "tier"],
  "properties": {
    "text": { "type": ["string", "null"] },
    "tier": {
      "type": "string",
      "enum": ["scaffold", "inferred", "confirmed", "deprecated"]
    },
    "evidence": {
      "type": "array",
      "items": { "type": "string", "pattern": "\\S" }
    },
    "by": { "type": "string", "pattern": "\\S" },
    "at": { "type": "string", "pattern": "\\S" }
  },
  "if": {
    "properties": { "tier": { "const": "scaffold" } },
    "required": ["tier"]
  },
  "then": {
    "properties": { "text": { "const": null } }
  },
  "else": {
    "required": ["evidence"],
    "properties": {
      "evidence": { "type": "array", "minItems": 1 }
    }
  }
}
